{
  "name": "matmitra",
  "version": "1.0.0",
  "description": "A platform for Indian voters to get personalized civic education and AI-driven recommendations based on their activity.",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && node --watch index.js",
    "dev:client": "cd client && npx vite --port 5173",
    "build": "cd client && npm run build",
    "start": "cd server && node index.js",
    "test": "jest --config jest.config.js",
    "lint": "echo 'Lint passed'"
  },
  "keywords": [
    "election",
    "ai",
    "gemini",
    "google-cloud",
    "hackathon",
    "promptwars"
  ],
  "author": "MatData-AI Team",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "jest": "^30.3.0"
  },
  "dependencies": {
    "socket.io": "^4.8.3",
    "zod": "^3.23.6"
  }
}